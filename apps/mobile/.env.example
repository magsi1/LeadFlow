EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Next.js API base (port 3000) — required for saveLead / physical devices (use LAN IP, not localhost).
# Copy to .env.local and set your PC IPv4 from `ipconfig` (Windows) or `ipconfig getifaddr en0` (Mac).
EXPO_PUBLIC_API_URL=http://YOUR_LOCAL_IP:3000

# Nest API (port 4000) — inbox, analytics, etc.
# EXPO_PUBLIC_NEST_API_URL=http://YOUR_LOCAL_IP:4000

# Optional: direct OpenAI from the app (default model gpt-4o-mini). Key is exposed in the bundle.
# EXPO_PUBLIC_OPENAI_API_KEY=sk-...
# EXPO_PUBLIC_OPENAI_MODEL=gpt-4o-mini

# Without EXPO_PUBLIC_OPENAI_API_KEY: use Supabase Edge Function `ai-chat-completion` + session:
#   supabase secrets set OPENAI_API_KEY=sk-...
