# LeadFlow runtime config (used via --dart-define or --dart-define-from-file)

# Environment name
APP_ENV=demo
LEADFLOW_ENV=demo

# Supabase
# Set APP_ENV=supabase and LEADFLOW_DEMO_MODE=false to enable auth-protected CRM mode.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Backend
LEADFLOW_BACKEND_BASE_URL=https://api.your-domain.com
LEADFLOW_AUTH_TOKEN=

# Integrations / AI (optional)
LEADFLOW_OPENAI_API_KEY=
LEADFLOW_META_APP_ID=
LEADFLOW_META_CONFIG_ID=

# Feature flags
# true = local/demo repositories
# false = real backend repositories
LEADFLOW_DEMO_MODE=true
LEADFLOW_AI_MODE=false
