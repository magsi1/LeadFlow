{
  "name": "leadflow-mobile-monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @leadflow/api & npm run dev -w @leadflow/mobile",
    "dev:api": "npm run dev -w @leadflow/api",
    "dev:mobile": "npm run dev -w @leadflow/mobile",
    "dev:web": "npm run dev -w @leadflow/web",
    "build": "npm run build -ws",
    "lint": "npm run lint -ws"
  }
}
